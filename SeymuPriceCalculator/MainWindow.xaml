<Window x:Class="SeymuPriceCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seymu — Calculadora de Madera"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
        FontSize="16"
        Background="#ECEEF0"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>

        <!-- ─── Paleta ─── -->
        <SolidColorBrush x:Key="VerdePrimario"    Color="#2D6A27"/>
        <SolidColorBrush x:Key="VerdeOscuro"      Color="#1E4A1B"/>
        <SolidColorBrush x:Key="VerdeLight"       Color="#C8E6C4"/>
        <SolidColorBrush x:Key="VerdeMuy"         Color="#EAF4E8"/>
        <SolidColorBrush x:Key="FondoGeneral"     Color="#ECEEF0"/>
        <SolidColorBrush x:Key="Tarjeta"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextoPrimario"    Color="#111111"/>
        <SolidColorBrush x:Key="TextoSecundario"  Color="#555555"/>
        <SolidColorBrush x:Key="BordeInput"       Color="#BBBBBB"/>
        <SolidColorBrush x:Key="FondoInput"       Color="#F5F5F5"/>
        <SolidColorBrush x:Key="BordeInputActivo" Color="#2D6A27"/>
        <SolidColorBrush x:Key="AzulAccento"      Color="#0068C0"/>
        <SolidColorBrush x:Key="RojoAccento"      Color="#B52B1E"/>
        <SolidColorBrush x:Key="AmarilloAccento"  Color="#B06A00"/>
        <SolidColorBrush x:Key="BordeTarjeta"     Color="#D8D8D8"/>

        <!-- ─── Etiqueta de Campo ─── -->
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- ─── TextBox Fluent ─── -->
        <Style TargetType="TextBox">
            <Setter Property="Height"                   Value="42"/>
            <Setter Property="FontSize"                 Value="15"/>
            <Setter Property="Foreground"               Value="{StaticResource TextoPrimario}"/>
            <Setter Property="Background"               Value="{StaticResource FondoInput}"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness"          Value="0,0,0,3"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BordeInput}"/>
            <Setter Property="Margin"                   Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="borde"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="borde" Property="BorderBrush"
                                        Value="{StaticResource BordeInputActivo}"/>
                                <Setter TargetName="borde" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borde" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── ComboBox ─── -->
        <Style TargetType="ComboBox">
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Foreground"      Value="{StaticResource TextoPrimario}"/>
            <Setter Property="Background"      Value="{StaticResource FondoInput}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BordeInput}"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="Padding"         Value="10,2"/>
            <Setter Property="Margin"          Value="0,0,0,10"/>
        </Style>

        <!-- ─── Botón Base ─── -->
        <Style x:Key="BotonBase" TargetType="Button">
            <Setter Property="Height"          Value="46"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="fondo"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="fondo" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="fondo" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BotonVerde" TargetType="Button" BasedOn="{StaticResource BotonBase}">
            <Setter Property="Background" Value="{StaticResource VerdePrimario}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="BotonAzul" TargetType="Button" BasedOn="{StaticResource BotonBase}">
            <Setter Property="Background" Value="{StaticResource AzulAccento}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="BotonGris" TargetType="Button" BasedOn="{StaticResource BotonBase}">
            <Setter Property="Background" Value="#777777"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ─── Botón Ghost ─── -->
        <Style x:Key="BotonGhost" TargetType="Button">
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{StaticResource VerdePrimario}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="{StaticResource VerdePrimario}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borde"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borde" Property="Background"
                                        Value="{StaticResource VerdeMuy}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── DataGrid Row: selección en verde, nunca azul ─── -->
        <Style TargetType="DataGridRow">
            <Setter Property="Height"   Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DCF0D9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C4"/>
                    <Setter Property="Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── DataGrid Cell: elimina el recuadro azul de foco ─── -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Foreground"  Value="#111111"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected"                  Value="True"/>
                        <Condition Property="Selector.IsSelectionActive"  Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground"  Value="#111111"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- ─── DataGrid Header ─── -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#2D6A27"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderBrush"     Value="#1E4A1B"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  RAÍZ                                                    -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Grid Margin="18,14,18,18" Background="{StaticResource FondoGeneral}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  BARRA SUPERIOR                                      -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource VerdePrimario}"
                CornerRadius="12"
                Padding="16,12"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="48" Height="48"
                            CornerRadius="10"
                            Background="#FFFFFF22"
                            Margin="0,0,14,0">
                        <Grid>
                            <TextBlock x:Name="txtLetraLogo"
                                       Text="S"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image x:Name="imgLogoEmpresa"
                                   Stretch="Uniform"
                                   Visibility="Collapsed"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtNombreEmpresa"
                                   Text="SEYMU"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Calculadora de Madera"
                                   FontSize="12"
                                   Foreground="#CCFFCC"/>

                        <TextBlock x:Name="lblSync"
                   FontSize="11"
                   Foreground="#CCFFCC"
                   VerticalAlignment="Center"
                   Margin="12,0,0,0"
                   Text=""/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="⚙   Configuración"
                        Width="175" Height="40"
                        Cursor="Hand"
                        FontSize="14" FontWeight="Bold"
                        Foreground="{StaticResource VerdePrimario}"
                        Background="White"
                        Click="AbrirConfiguracion_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="14,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  TARJETA CLIENTE                                     -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
        Background="{StaticResource Tarjeta}"
        CornerRadius="10"
        BorderBrush="{StaticResource BordeTarjeta}"
        BorderThickness="1"
        Padding="20,12"
        Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Etiqueta lateral -->
                <TextBlock Grid.Column="0" Grid.RowSpan="2"
                   Text="CLIENTE"
                   FontSize="10" FontWeight="Bold"
                   Foreground="{StaticResource VerdePrimario}"
                   VerticalAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>

                <Border Grid.Column="1" Grid.RowSpan="2"
                Width="2" Background="{StaticResource VerdeLight}"
                VerticalAlignment="Stretch" Margin="8,2"/>

                <!-- ── NOMBRE con sugerencias ── -->
                <TextBlock Grid.Column="2" Grid.Row="0"
                   Text="NOMBRE DEL CLIENTE"
                   Style="{StaticResource LabelCampo}"/>

                <!-- Contenedor relativo para poder poner el popup encima -->
                <Grid Grid.Column="2" Grid.Row="1">
                    <TextBox x:Name="txtNombre"
                     Margin="0"
                     PreviewTextInput="SoloLetras"
                     TextChanged="txtNombre_TextChanged"
                     LostFocus="txtNombre_LostFocus"
                     PreviewKeyDown="txtNombre_PreviewKeyDown"/>

                    <Popup x:Name="popupNombre"
                   PlacementTarget="{Binding ElementName=txtNombre}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                        <Border Background="White"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        MinWidth="{Binding ActualWidth, ElementName=txtNombre}">
                            <ListBox x:Name="lstSugerenciasNombre"
                             MaxHeight="200"
                             FontSize="14"
                             BorderThickness="0"
                             SelectionChanged="lstSugerenciasNombre_SelectionChanged"
                             PreviewKeyDown="lstSugerencias_PreviewKeyDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="Cursor"  Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EAF4E8"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#C8E6C4"/>
                                                <Setter Property="Foreground" Value="#111111"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nombre}"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                            <TextBlock Text="{Binding Telefono}"
                                               FontSize="12"
                                               Foreground="#888888"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <!-- ── TELÉFONO con sugerencias ── -->
                <TextBlock Grid.Column="4" Grid.Row="0"
                   Text="NÚMERO DE TELÉFONO"
                   Style="{StaticResource LabelCampo}"/>

                <Grid Grid.Column="4" Grid.Row="1">
                    <TextBox x:Name="txtTelefono"
                     Margin="0"
                     PreviewTextInput="SoloNumeros"
                     TextChanged="txtTelefono_TextChanged"
                     LostFocus="txtTelefono_LostFocus"
                     PreviewKeyDown="txtTelefono_PreviewKeyDown"/>

                    <Popup x:Name="popupTelefono"
                   PlacementTarget="{Binding ElementName=txtTelefono}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                        <Border Background="White"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        MinWidth="{Binding ActualWidth, ElementName=txtTelefono}">
                            <ListBox x:Name="lstSugerenciasTelefono"
                             MaxHeight="200"
                             FontSize="14"
                             BorderThickness="0"
                             SelectionChanged="lstSugerenciasTelefono_SelectionChanged"
                             PreviewKeyDown="lstSugerencias_PreviewKeyDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="Cursor"  Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EAF4E8"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#C8E6C4"/>
                                                <Setter Property="Foreground" Value="#111111"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nombre}"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                            <TextBlock Text="{Binding Telefono}"
                                               FontSize="12"
                                               Foreground="#888888"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  CUERPO                                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── PANEL IZQUIERDO ──────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource Tarjeta}"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BordeTarjeta}"
                    BorderThickness="1"
                    Padding="18,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Título  -->
                        <RowDefinition Height="Auto"/>
                        <!-- Madera  -->
                        <RowDefinition Height="Auto"/>
                        <!-- Largo   -->
                        <RowDefinition Height="Auto"/>
                        <!-- Anchos  -->
                        <RowDefinition Height="Auto"/>
                        <!-- Grosor  -->
                        <RowDefinition Height="Auto"/>
                        <!-- Precio  -->
                        <RowDefinition Height="*"/>
                        <!-- Espacio -->
                        <RowDefinition Height="Auto"/>
                        <!-- Botones -->
                    </Grid.RowDefinitions>

                    <!-- Título -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="5" Height="22" CornerRadius="3"
                                Background="{StaticResource VerdePrimario}"
                                Margin="0,0,10,0"/>
                        <TextBlock Text="Nueva Pieza"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextoPrimario}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Tipo de Madera -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="TIPO DE MADERA" Style="{StaticResource LabelCampo}"/>
                        <ComboBox x:Name="cmbMadera" SelectedIndex="0">
                            <ComboBoxItem Content="Cedro"/>
                            <ComboBoxItem Content="Guanacaste"/>
                            <ComboBoxItem Content="Melina"/>
                            <ComboBoxItem Content="Teca"/>
                            <ComboBoxItem Content="Caobilla"/>
                            <ComboBoxItem Content="Cenizaro"/>
                            <ComboBoxItem Content="Laurel"/>
                            <ComboBoxItem Content="Pino"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Largo -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="LARGO" Style="{StaticResource LabelCampo}"/>
                        <TextBox x:Name="txtLargo" PreviewTextInput="SoloDecimal"/>
                    </StackPanel>

                    <!-- Anchos -->
                    <StackPanel Grid.Row="3">
                        <TextBlock Text="ANCHOS" Style="{StaticResource LabelCampo}"/>
                        <TextBox x:Name="txtAnchos" PreviewTextInput="SoloNumerosYGuion"/>
                    </StackPanel>

                    <!-- Grosor -->
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="GROSOR (PULGADAS)" Style="{StaticResource LabelCampo}"/>
                        <ComboBox x:Name="cmbGrosor" SelectedIndex="0">
                            <ComboBoxItem Content="0.5"/>
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="1.5"/>
                            <ComboBoxItem Content="1.75"/>
                            <ComboBoxItem Content="1.125"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Precio -->
                    <StackPanel Grid.Row="5">
                        <TextBlock Text="PRECIO POR PULGADA" Style="{StaticResource LabelCampo}"/>
                        <TextBox x:Name="txtPrecio"
                                 Height="38" FontSize="14"
                                 PreviewTextInput="SoloDecimal"/>
                    </StackPanel>

                    <!-- Botones -->
                    <StackPanel Grid.Row="7" Margin="0,6,0,0">
                        <Button x:Name="btnAgregar"
                                Content="＋   Agregar Pieza"
                                Height="34" FontSize="18"
                                Style="{StaticResource BotonVerde}"
                                Click="AgregarPieza_Click"
                                Margin="0,0,0,10"/>

                        <Grid x:Name="panelEdicion" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnGuardar"
                                    Grid.Column="0"
                                    Content="✔  Guardar"
                                    Height="48" FontSize="14"
                                    Style="{StaticResource BotonAzul}"
                                    Click="GuardarEdicion_Click"/>
                            <Button x:Name="btnCancelar"
                                    Grid.Column="2"
                                    Content="✖  Cancelar"
                                    Height="48" FontSize="14"
                                    Style="{StaticResource BotonGris}"
                                    Click="CancelarEdicion_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── PANEL DERECHO: Tabla + Totales ───────────── -->
            <Border Grid.Column="2"
                    Background="{StaticResource Tarjeta}"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BordeTarjeta}"
                    BorderThickness="1"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header tabla -->
                    <Border Grid.Row="0"
                            Background="{StaticResource VerdePrimario}"
                            CornerRadius="10,10,0,0"
                            Padding="20,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="5" Height="20" CornerRadius="3"
                                    Background="White"
                                    Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Detalle de Piezas"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid x:Name="dgPiezas"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FontSize="14"
                              RowHeight="46"
                              ColumnHeaderHeight="44"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E5E5E5"
                              AlternatingRowBackground="#F7FAF7"
                              Background="White"
                              BorderThickness="0"
                              SelectionMode="Single"
                              HorizontalAlignment="Stretch"
                              VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="#"
                                                Binding="{Binding Numero}" Width="38">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
                                        <Setter Property="Padding"    Value="10,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Madera"
                                                Binding="{Binding TipoMadera}" Width="105">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding"    Value="10,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Anchos"
                                                Binding="{Binding Anchos}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextoSecundario}"/>
                                        <Setter Property="Padding"    Value="10,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Largo"
                                                Binding="{Binding Largo}" Width="64">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Σ Ancho"
                                                Binding="{Binding TotalAncho}" Width="82">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Grosor"
                                                Binding="{Binding Grosor}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Pulgadas"
                                                Binding="{Binding TotalBase}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Precio en azul -->
                            <DataGridTextColumn Header="Precio"
                                                Binding="{Binding Precio, StringFormat='₡ {0:N2}'}"
                                                Width="122">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"          Value="{StaticResource AzulAccento}"/>
                                        <Setter Property="FontWeight"          Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding"             Value="0,0,12,0"/>
                                        <Setter Property="VerticalAlignment"   Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Total también en azul -->
                            <DataGridTextColumn Header="Total"
                                                Binding="{Binding Total, StringFormat='₡ {0:N2}'}"
                                                Width="126">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"          Value="{StaticResource AzulAccento}"/>
                                        <Setter Property="FontWeight"          Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding"             Value="0,0,12,0"/>
                                        <Setter Property="VerticalAlignment"   Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Acciones -->
                            <DataGridTemplateColumn Header="Acciones" Width="210">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="6,0">
                                            <Button Content="✏  Editar"
                                                    Tag="{Binding}"
                                                    Click="EditarPieza_Click"
                                                    Height="32" Width="88"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    FontSize="13" FontWeight="Bold"
                                                    Foreground="White"
                                                    Background="{StaticResource AmarilloAccento}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="7" Padding="8,0">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.83"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Content="🗑  Borrar"
                                                    Tag="{Binding}"
                                                    Click="EliminarPieza_Click"
                                                    Height="32" Width="92"
                                                    Cursor="Hand"
                                                    FontSize="13" FontWeight="Bold"
                                                    Foreground="White"
                                                    Background="{StaticResource RojoAccento}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="7" Padding="8,0">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.83"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ── FRANJA TOTALES ── -->
                    <Border Grid.Row="2"
                            Background="#F0F7EF"
                            CornerRadius="0,0,10,10"
                            BorderBrush="#C8DEC6"
                            BorderThickness="0,2,0,0"
                            Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="2"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Subtotal -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Subtotal"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblSubtotal"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource AzulAccento}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- IVA -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="24,0">
                                <TextBlock Text="IVA 13%"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextoSecundario}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblIVA"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource AzulAccento}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Divisor -->
                            <Border Grid.Column="3"
                                    Background="{StaticResource VerdeLight}"
                                    VerticalAlignment="Stretch" Margin="0,4"/>

                            <!-- Total -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="18,0">
                                <TextBlock Text="TOTAL"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource VerdePrimario}"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="lblTotal"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource VerdePrimario}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Botón Imprimir -->
                            <Button Grid.Column="6"
                                    Content="🖨   Guardar / Imprimir"
                                    Width="220" Height="48"
                                    FontSize="15"
                                    Style="{StaticResource BotonVerde}"
                                    Click="GuardarCotizacion_Click"/>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>