<UserControl x:Class="SeymuPriceCalculator.Views.HistorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
             FontSize="14"
             Background="#F0F0F0">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Verde"    Color="#2D6A27"/>
        <SolidColorBrush x:Key="Azul"     Color="#0068C0"/>
        <SolidColorBrush x:Key="Texto"    Color="#111111"/>
        <SolidColorBrush x:Key="Gris"     Color="#555555"/>
        <SolidColorBrush x:Key="Borde"    Color="#DEDEDE"/>
        <SolidColorBrush x:Key="FondoBox" Color="#F5F5F5"/>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="CalendarDayButton">
            <Setter Property="Width"    Value="52"/>
            <Setter Property="Height"   Value="52"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="CalendarButton">
            <Setter Property="Width"    Value="104"/>
            <Setter Property="Height"   Value="52"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Calendar">
            <Setter Property="Width"    Value="420"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>

        <Style TargetType="CalendarItem">
            <Setter Property="Width"  Value="420"/>
            <Setter Property="Height" Value="380"/>
        </Style>

        <!-- TextBox de búsqueda -->
        <Style x:Key="TxtBusqueda" TargetType="TextBox">
            <Setter Property="Height"                   Value="40"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Foreground"               Value="{StaticResource Texto}"/>
            <Setter Property="Background"               Value="{StaticResource FondoBox}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource Borde}"/>
            <Setter Property="BorderThickness"          Value="0,0,0,2"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Verde}"/>
                                <Setter TargetName="b" Property="Background"  Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón acción -->
        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Row -->
        <Style TargetType="DataGridRow">
            <Setter Property="Height"   Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DCF0D9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C4"/>
                    <Setter Property="Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Foreground"   Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#2D6A27"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderBrush"     Value="#1E4A1B"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Barra búsqueda  -->
            <RowDefinition Height="*"/>
            <!-- Tabla           -->
            <RowDefinition Height="Auto"/>
            <!-- Panel detalle   -->
        </Grid.RowDefinitions>

        <!-- ── BARRA DE BÚSQUEDA ─────────────────────────── -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource Borde}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Búsqueda por cliente -->
                <TextBox x:Name="txtBuscar"
                         Grid.Column="0"
                         Style="{StaticResource TxtBusqueda}"
                         TextChanged="txtBuscar_TextChanged">
                    <TextBox.ToolTip>Buscar por nombre de cliente</TextBox.ToolTip>
                </TextBox>

                <!-- Placeholder manual -->
                <TextBlock Grid.Column="0"
                           Text="🔍  Buscar por cliente..."
                           Foreground="#AAAAAA"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscar}"
                                             Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Filtro fecha -->
                <DatePicker x:Name="dpFecha"
                            Grid.Column="2"
                            Height="40"
                            FontSize="13"
                            SelectedDateChanged="dpFecha_SelectedDateChanged"
                            ToolTip="Filtrar por fecha"/>

                <!-- Botón limpiar filtros -->
                <Button Grid.Column="4"
                        Content="✖  Limpiar"
                        Width="100"
                        Background="#777777"
                        Style="{StaticResource BtnAccion}"
                        Click="LimpiarFiltros_Click"/>

                <!-- Botón reimprimir -->
                <Button Grid.Column="6"
                        Content="🖨  Reimprimir"
                        Width="130"
                        Background="{StaticResource Verde}"
                        Style="{StaticResource BtnAccion}"
                        Click="Reimprimir_Click"/>
            </Grid>
        </Border>

        <!-- ── TABLA DE COTIZACIONES ──────────────────────── -->
        <DataGrid x:Name="dgHistorial"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeight="44"
                  ColumnHeaderHeight="42"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EBEBEB"
                  AlternatingRowBackground="#F7FAF7"
                  Background="White"
                  BorderThickness="0"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch"
                  VerticalScrollBarVisibility="Auto"
                  SelectionChanged="dgHistorial_SelectionChanged">

            <DataGrid.Columns>

                <DataGridTextColumn Header="N°"
                                    Binding="{Binding Id}" Width="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#777777"/>
                            <Setter Property="Padding"    Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Fecha"
                                    Binding="{Binding Fecha}" Width="155">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Cliente"
                                    Binding="{Binding Cliente}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding"    Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Subtotal"
                                    Binding="{Binding Subtotal, StringFormat='₡ {0:N2}'}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"          Value="#0068C0"/>
                            <Setter Property="FontWeight"          Value="SemiBold"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding"             Value="0,0,12,0"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="IVA"
                                    Binding="{Binding IVA, StringFormat='₡ {0:N2}'}"
                                    Width="115">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"          Value="#0068C0"/>
                            <Setter Property="FontWeight"          Value="SemiBold"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding"             Value="0,0,12,0"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Total"
                                    Binding="{Binding Total, StringFormat='₡ {0:N2}'}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"          Value="#2D6A27"/>
                            <Setter Property="FontWeight"          Value="Bold"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding"             Value="0,0,12,0"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ── PANEL DE DETALLE DE PIEZAS ────────────────── -->
        <Border x:Name="panelDetalle"
                Grid.Row="2"
                Background="#F5F9F5"
                BorderBrush="#C8DEC6"
                BorderThickness="0,2,0,0"
                Padding="16,12"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Encabezado del detalle -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Width="4" Height="18" CornerRadius="2"
                            Background="{StaticResource Verde}"
                            Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblDetalleCliente"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#111111"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Lista de piezas de la cotización seleccionada -->
                <DataGrid x:Name="dgDetallePiezas"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MaxHeight="180"
                          RowHeight="36"
                          ColumnHeaderHeight="36"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E0E0E0"
                          Background="White"
                          BorderBrush="{StaticResource Borde}"
                          BorderThickness="1"
                          FontSize="13">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Madera"
                                            Binding="{Binding TipoMadera}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding"    Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Anchos"
                                            Binding="{Binding Anchos}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#555555"/>
                                    <Setter Property="Padding"    Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Largo"
                                            Binding="{Binding Largo}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Grosor"
                                            Binding="{Binding Grosor}" Width="72">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Pulgadas"
                                            Binding="{Binding Pulgadas}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Precio"
                                            Binding="{Binding Precio, StringFormat='₡ {0:N2}'}"
                                            Width="115">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"          Value="#0068C0"/>
                                    <Setter Property="FontWeight"          Value="SemiBold"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding"             Value="0,0,10,0"/>
                                    <Setter Property="VerticalAlignment"   Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding Total, StringFormat='₡ {0:N2}'}"
                                            Width="115">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"          Value="#0068C0"/>
                                    <Setter Property="FontWeight"          Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding"             Value="0,0,10,0"/>
                                    <Setter Property="VerticalAlignment"   Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>