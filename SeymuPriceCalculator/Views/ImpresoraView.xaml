<UserControl x:Class="SeymuPriceCalculator.Views.ImpresoraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
             FontSize="15"
             Background="#F0F0F0"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Verde"    Color="#2D6A27"/>
        <SolidColorBrush x:Key="Texto"    Color="#111111"/>
        <SolidColorBrush x:Key="Gris"     Color="#444444"/>
        <SolidColorBrush x:Key="Borde"    Color="#CCCCCC"/>
        <SolidColorBrush x:Key="FondoBox" Color="#F5F5F5"/>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Gris}"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{StaticResource FondoBox}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Borde}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel Margin="28,24,28,28" MaxWidth="500" HorizontalAlignment="Left">
            
            <!-- Título -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                <Border Width="5" Height="26" CornerRadius="3"
                        Background="{StaticResource Verde}"
                        Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Configuración de Impresora"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource Texto}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="SELECCIONAR IMPRESORA" Style="{StaticResource Lbl}"/>
            <ComboBox x:Name="cmbImpresoras" DisplayMemberPath="."/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <!-- Botón Guardar -->
                <Button x:Name="btnGuardar"
                        Content="💾  Guardar Selección"
                        Height="48" Width="220"
                        Margin="0,0,16,0"
                        FontSize="15" FontWeight="Bold"
                        Foreground="White"
                        Background="{StaticResource Verde}"
                        Click="Guardar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Botón Prueba -->
                <Button x:Name="btnPrueba"
                        Content="📄  Impresión de Prueba"
                        Height="48" Width="220"
                        FontSize="15" FontWeight="Bold"
                        Foreground="{StaticResource Verde}"
                        Background="Transparent"
                        BorderBrush="{StaticResource Verde}"
                        BorderThickness="2"
                        Click="Prueba_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Verde}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <TextBlock x:Name="lblStatus"
                       Margin="0,20,0,0"
                       FontSize="14" FontWeight="SemiBold"
                       Visibility="Collapsed"/>

            <!-- Info Ayuda -->
            <Border Margin="0,40,0,0" 
                    Background="#EAF4E8" 
                    Padding="16" 
                    CornerRadius="8"
                    BorderBrush="#C8E6C4"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💡 Ayuda" FontWeight="Bold" Foreground="#1E4A1B" Margin="0,0,0,8"/>
                    <TextBlock Text="Si tu impresora no aparece en la lista, asegúrate de que esté instalada correctamente en Windows (Panel de Control > Impresoras)." 
                               Foreground="#2D6A27" FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Text="El sistema usará esta impresora seleccionada para todos los recibos y tickets." 
                               Foreground="#2D6A27" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
