<UserControl x:Class="SeymuPriceCalculator.Views.AdministrarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
             FontSize="14"
             Background="#F0F0F0">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Verde"    Color="#2D6A27"/>
        <SolidColorBrush x:Key="Rojo"     Color="#B52B1E"/>
        <SolidColorBrush x:Key="Azul"     Color="#0068C0"/>
        <SolidColorBrush x:Key="Amarillo" Color="#B06A00"/>
        <SolidColorBrush x:Key="Texto"    Color="#111111"/>
        <SolidColorBrush x:Key="Gris"     Color="#555555"/>
        <SolidColorBrush x:Key="Borde"    Color="#DEDEDE"/>
        <SolidColorBrush x:Key="FondoBox" Color="#F5F5F5"/>

        <!-- TextBox -->
        <Style x:Key="TxtAdmin" TargetType="TextBox">
            <Setter Property="Height"                   Value="42"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Background"               Value="{StaticResource FondoBox}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource Borde}"/>
            <Setter Property="BorderThickness"          Value="0,0,0,2"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Verde}"/>
                                <Setter TargetName="b" Property="Background"  Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón acción -->
        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón inline en tabla -->
        <Style x:Key="BtnTabla" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.83"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab personalizado -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="Foreground"      Value="{StaticResource Gris}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="fondo"
                                Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="fondo" Property="BorderBrush"
                                        Value="{StaticResource Verde}"/>
                                <Setter Property="Foreground" Value="{StaticResource Verde}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Verde}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGridRow">
            <Setter Property="Height"   Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DCF0D9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8E6C4"/>
                    <Setter Property="Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Foreground"  Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#2D6A27"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderBrush"     Value="#1E4A1B"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </UserControl.Resources>

    <TabControl Background="White" BorderThickness="0">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: CLIENTES                                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <TabItem Header="👤  Clientes">
            <Grid Margin="20,16,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Formulario -->
                <Border Grid.Row="0"
                        Background="#F8FAF8"
                        BorderBrush="{StaticResource Borde}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtClienteNombre" Grid.Column="0"
                                 Style="{StaticResource TxtAdmin}"
                                 ToolTip="Nombre del cliente"/>
                        <TextBlock Grid.Column="0" Text="Nombre del cliente"
                                   Foreground="#AAAAAA" FontSize="13"
                                   VerticalAlignment="Center" Margin="14,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtClienteNombre}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox x:Name="txtClienteTelefono" Grid.Column="2"
                                 Style="{StaticResource TxtAdmin}"
                                 ToolTip="Teléfono"/>
                        <TextBlock Grid.Column="2" Text="Teléfono"
                                   Foreground="#AAAAAA" FontSize="13"
                                   VerticalAlignment="Center" Margin="14,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtClienteTelefono}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button x:Name="btnAgregarCliente" Grid.Column="4"
                                Content="＋  Agregar" Width="120"
                                Background="{StaticResource Verde}"
                                Style="{StaticResource BtnAccion}"
                                Click="AgregarCliente_Click"/>

                        <Button x:Name="btnGuardarCliente" Grid.Column="6"
                                Content="✔  Guardar" Width="120"
                                Background="{StaticResource Azul}"
                                Style="{StaticResource BtnAccion}"
                                Visibility="Collapsed"
                                Click="GuardarCliente_Click"/>

                        <Button x:Name="btnCancelarCliente" Grid.Column="8"
                                Content="✖  Cancelar" Width="110"
                                Background="#777777"
                                Style="{StaticResource BtnAccion}"
                                Visibility="Collapsed"
                                Click="CancelarCliente_Click"/>
                    </Grid>
                </Border>

                <!-- Búsqueda -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <TextBox x:Name="txtBuscarCliente"
                             Style="{StaticResource TxtAdmin}"
                             TextChanged="txtBuscarCliente_TextChanged"/>
                    <TextBlock Text="🔍  Buscar cliente..."
                               Foreground="#AAAAAA" FontSize="13"
                               VerticalAlignment="Center" Margin="14,0,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtBuscarCliente}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Tabla clientes -->
                <DataGrid x:Name="dgClientes" Grid.Row="2"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          BorderBrush="{StaticResource Borde}" BorderThickness="1"
                          Background="White" SelectionMode="Single"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"    Value="12,0"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"    Value="12,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"    Value="12,0"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Acciones" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0">
                                        <Button Content="✏  Editar" Tag="{Binding}"
                                                Click="EditarCliente_Click"
                                                Width="86" Padding="8,0" Margin="0,0,6,0"
                                                Background="{StaticResource Amarillo}"
                                                Style="{StaticResource BtnTabla}"/>
                                        <Button Content="🗑  Borrar" Tag="{Binding}"
                                                Click="EliminarCliente_Click"
                                                Width="86" Padding="8,0"
                                                Background="{StaticResource Rojo}"
                                                Style="{StaticResource BtnTabla}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: TIPOS DE MADERA                                 -->
        <!-- ═══════════════════════════════════════════════════ -->
        <TabItem Header="🪵  Tipos de Madera">
            <Grid Margin="20,16,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Panel izquierdo -->
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="lblTituloMadera"
                               Text="AGREGAR TIPO DE MADERA"
                               FontSize="12" FontWeight="Bold"
                               Foreground="#555555" Margin="0,0,0,8"/>

                    <TextBox x:Name="txtNuevaMadera"
                             Style="{StaticResource TxtAdmin}"
                             Margin="0,0,0,10"/>

                    <!-- Botón agregar -->
                    <Button x:Name="btnAgregarMadera"
                            Content="＋  Agregar Madera"
                            Height="46" FontSize="14" FontWeight="Bold"
                            Foreground="White"
                            Background="{StaticResource Verde}"
                            Style="{StaticResource BtnAccion}"
                            Margin="0,0,0,8"
                            Click="AgregarMadera_Click"/>

                    <!-- Botones edición (ocultos por defecto) -->
                    <Grid x:Name="panelBotonesMadera" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="✔  Guardar"
                                Height="46" FontSize="14" FontWeight="Bold"
                                Foreground="White"
                                Background="{StaticResource Azul}"
                                Style="{StaticResource BtnAccion}"
                                Click="GuardarMadera_Click"/>
                        <Button Grid.Column="2"
                                Content="✖  Cancelar"
                                Height="46" FontSize="14" FontWeight="Bold"
                                Foreground="White"
                                Background="#777777"
                                Style="{StaticResource BtnAccion}"
                                Click="CancelarMadera_Click"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource Borde}"
                            Margin="0,20,0,16"/>

                    <TextBlock Text="Las maderas aparecerán automáticamente en la calculadora."
                               FontSize="12" Foreground="#888888" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Tabla maderas -->
                <DataGrid x:Name="dgMaderas" Grid.Column="2"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          BorderBrush="{StaticResource Borde}" BorderThickness="1"
                          Background="White" SelectionMode="Single"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tipo de Madera"
                                            Binding="{Binding}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"    Value="14,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Acciones" Width="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0">
                                        <Button Content="✏  Editar" Tag="{Binding}"
                                                Click="EditarMadera_Click"
                                                Width="82" Padding="8,0" Margin="0,0,6,0"
                                                Background="{StaticResource Amarillo}"
                                                Style="{StaticResource BtnTabla}"/>
                                        <Button Content="🗑  Borrar" Tag="{Binding}"
                                                Click="EliminarMadera_Click"
                                                Width="82" Padding="8,0"
                                                Background="{StaticResource Rojo}"
                                                Style="{StaticResource BtnTabla}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: GROSORES                                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <TabItem Header="📐  Grosores">
            <Grid Margin="20,16,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Panel izquierdo -->
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="lblTituloGrosor"
                               Text="AGREGAR GROSOR (PULGADAS)"
                               FontSize="12" FontWeight="Bold"
                               Foreground="#555555" Margin="0,0,0,8"/>

                    <TextBox x:Name="txtNuevoGrosor"
                             Style="{StaticResource TxtAdmin}"
                             Margin="0,0,0,10"/>

                    <!-- Botón agregar -->
                    <Button x:Name="btnAgregarGrosor"
                            Content="＋  Agregar Grosor"
                            Height="46" FontSize="14" FontWeight="Bold"
                            Foreground="White"
                            Background="{StaticResource Verde}"
                            Style="{StaticResource BtnAccion}"
                            Margin="0,0,0,8"
                            Click="AgregarGrosor_Click"/>

                    <!-- Botones edición (ocultos por defecto) -->
                    <Grid x:Name="panelBotonesGrosor" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="✔  Guardar"
                                Height="46" FontSize="14" FontWeight="Bold"
                                Foreground="White"
                                Background="{StaticResource Azul}"
                                Style="{StaticResource BtnAccion}"
                                Click="GuardarGrosor_Click"/>
                        <Button Grid.Column="2"
                                Content="✖  Cancelar"
                                Height="46" FontSize="14" FontWeight="Bold"
                                Foreground="White"
                                Background="#777777"
                                Style="{StaticResource BtnAccion}"
                                Click="CancelarGrosor_Click"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource Borde}"
                            Margin="0,20,0,16"/>

                    <TextBlock Text="Los grosores aparecerán automáticamente en la calculadora."
                               FontSize="12" Foreground="#888888" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Tabla grosores -->
                <DataGrid x:Name="dgGrosores" Grid.Column="2"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          BorderBrush="{StaticResource Borde}" BorderThickness="1"
                          Background="White" SelectionMode="Single"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Grosor (pulgadas)"
                                            Binding="{Binding}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"    Value="14,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Acciones" Width="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0">
                                        <Button Content="✏  Editar" Tag="{Binding}"
                                                Click="EditarGrosor_Click"
                                                Width="82" Padding="8,0" Margin="0,0,6,0"
                                                Background="{StaticResource Amarillo}"
                                                Style="{StaticResource BtnTabla}"/>
                                        <Button Content="🗑  Borrar" Tag="{Binding}"
                                                Click="EliminarGrosor_Click"
                                                Width="82" Padding="8,0"
                                                Background="{StaticResource Rojo}"
                                                Style="{StaticResource BtnTabla}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>