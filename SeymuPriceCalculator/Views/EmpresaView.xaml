<UserControl x:Class="SeymuPriceCalculator.Views.EmpresaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
             FontSize="15"
             Background="#F0F0F0">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Verde"    Color="#2D6A27"/>
        <SolidColorBrush x:Key="Texto"    Color="#111111"/>
        <SolidColorBrush x:Key="Gris"     Color="#444444"/>
        <SolidColorBrush x:Key="Borde"    Color="#CCCCCC"/>
        <SolidColorBrush x:Key="FondoBox" Color="#F5F5F5"/>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Gris}"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="FontSize"                 Value="15"/>
            <Setter Property="Foreground"               Value="{StaticResource Texto}"/>
            <Setter Property="Background"               Value="{StaticResource FondoBox}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource Borde}"/>
            <Setter Property="BorderThickness"          Value="0,0,0,2"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"                   Value="0,0,0,18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Verde}"/>
                                <Setter TargetName="b" Property="Background"  Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,28" MaxWidth="580" HorizontalAlignment="Left">

            <!-- Título -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                <Border Width="5" Height="26" CornerRadius="3"
                        Background="{StaticResource Verde}"
                        Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Datos de la Empresa"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource Texto}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Nombre -->
            <TextBlock Text="NOMBRE DE LA EMPRESA" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="txtNombre"/>

            <!-- Ubicación -->
            <TextBlock Text="UBICACIÓN / DIRECCIÓN" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="txtUbicacion"/>

            <!-- Teléfono -->
            <TextBlock Text="TELÉFONO" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="txtTelefono"/>

            <!-- Correo -->
            <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="txtCorreo"/>

            <!-- Logo -->
            <TextBlock Text="LOGO DE LA EMPRESA" Style="{StaticResource Lbl}"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource FondoBox}"
                        BorderBrush="{StaticResource Borde}"
                        BorderThickness="0,0,0,2"
                        CornerRadius="6,6,0,0"
                        Height="44">
                    <TextBlock x:Name="txtLogoRuta"
                               Text="Sin logo seleccionado"
                               Foreground="#999999"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               TextTrimming="CharacterEllipsis"/>
                </Border>

                <Button Grid.Column="2"
                        Content="📁  Seleccionar"
                        Height="44"
                        Padding="18,0"
                        Cursor="Hand"
                        FontSize="14" FontWeight="Bold"
                        Foreground="White"
                        Background="{StaticResource Verde}"
                        Click="SeleccionarLogo_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Preview del logo -->
            <Border x:Name="borderLogo"
                    Width="180" Height="110"
                    HorizontalAlignment="Left"
                    BorderBrush="{StaticResource Borde}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,28"
                    Visibility="Collapsed">
                <Image x:Name="imgLogo"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- Separador -->
            <Border Height="1" Background="{StaticResource Borde}" Margin="0,0,0,24"/>

            <!-- Botón guardar -->
            <Button x:Name="btnGuardar"
                    Content="💾   Guardar Datos de Empresa"
                    Height="52"
                    Width="290"
                    HorizontalAlignment="Left"
                    FontSize="16" FontWeight="Bold"
                    Foreground="White"
                    Background="{StaticResource Verde}"
                    Click="GuardarEmpresa_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Mensaje OK -->
            <TextBlock x:Name="lblMensaje"
                       Visibility="Collapsed"
                       FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource Verde}"
                       Margin="0,16,0,0"
                       Text="✔  Datos guardados correctamente."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>